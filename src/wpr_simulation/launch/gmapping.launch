<launch>

  <!-- 可选：是否允许Gazebo在线拉取模型，默认关闭以避免SSL/代理抖动 -->
  <arg name="allow_online_models" default="false"/>
  <!-- 可选：是否在本launch中启动键盘控制 -->
  <arg name="enable_keyboard" default="true"/>
  <group unless="$(arg allow_online_models)">
    <env name="GAZEBO_MODEL_DATABASE_URI" value=""/>
    <env name="IGN_FUEL_SERVER_URI" value=""/>
    <env name="http_proxy" value=""/>
    <env name="https_proxy" value=""/>
    <env name="HTTP_PROXY" value=""/>
    <env name="HTTPS_PROXY" value=""/>
  </group>

  <!-- 1. 加载仿真环境：机器人模型、激光雷达、世界场景 -->
  <include file="$(find wpr_simulation)/launch/wpb_stage_robocup.launch"/>

  <!-- 2. 启动GMapping建图节点：核心SLAM算法，包含参数优化配置 -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping">
    
    <!-- 地图尺寸（适配仿真小场景） -->
    <param name="xmin" value="-20.0"/>
    <param name="xmax" value="20.0"/>
    <param name="ymin" value="-20.0"/>
    <param name="ymax" value="20.0"/>
    <param name="delta" value="0.05"/>
    
    <!-- 激光雷达（适配wpr_simulation的10m雷达） -->
    <param name="maxUrange" value="10.0"/>
    <param name="maxRange" value="12.0"/>
    
    <!-- 地图更新频率（解决卡顿+更新慢） -->
    <param name="map_update_interval" value="0.5"/>
    <param name="linearUpdate" value="0.1"/>
    <param name="angularUpdate" value="0.1"/>
    
    <!-- 粒子数（平衡精度和速度，虚拟机推荐50） -->
    <param name="particles" value="50"/>
    
  </node>

  <!-- 3. 启动RViz可视化工具：查看雷达数据、地图构建过程 -->
  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find wpr_simulation)/rviz/room.rviz"/>

  <!-- 4. 可选启动键盘控制节点：用键盘控制机器人移动 -->
  <group if="$(arg enable_keyboard)">
    <node pkg="wpr_simulation" type="keyboard_vel_ctrl" name="keyboard_vel_ctrl"/>
  </group>

</launch>
